# MongoDB Atlas connection string (get from https://mongodb.com/atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/secure-file-system?retryWrites=true&w=majority

# JWT secret key (generate a random 64-char hex string)
JWT_SECRET=your-random-64-character-hex-secret-key-here

# Port (Render sets this automatically, keep 3000 for local dev)
PORT=3000
